function App() {
  const [activeTrackId, setActiveTrackId] = useState(null);
  const [selectedTopic, setSelectedTopic] = useState(null);
  const [view, setView] = useState("home");
  const [completed, setCompleted] = useState({});
  const topRef = useRef(null);

  useEffect(() => {
    try { const s = localStorage.getItem("jcurr3"); if (s) setCompleted(JSON.parse(s)); } catch(e) {}
  }, []);

  const save = (updated) => {
    setCompleted(updated);
    try { localStorage.setItem("jcurr3", JSON.stringify(updated)); } catch(e) {}
  };

  const isComplete = (tid, topic) => !!completed[`${tid}::${topic}`];
  const markComplete = (tid, topic) => save({ ...completed, [`${tid}::${topic}`]: true });

  const totalLessons = tracks.reduce((a, t) => a + t.topics.length, 0);
  const completedCount = Object.keys(completed).length;
  const track = tracks.find(t => t.id === activeTrackId);

  const openLesson = (t, topic) => {
    setActiveTrackId(t.id);
    setSelectedTopic(topic);
    setView("lesson");
    setTimeout(() => topRef.current?.scrollIntoView({ behavior: "smooth" }), 50);
  };

  return (
    <div ref={topRef}>
      <div style={{borderBottom:"1px solid #1a1a1a",padding:"22px 28px",display:"flex",alignItems:"center",justifyContent:"space-between",position:"sticky",top:0,background:"#0D0D0D",zIndex:10}}>
        <div onClick={() => setView("home")} style={{cursor:"pointer"}}>
          <div style={{fontFamily:"'Playfair Display',serif",fontSize:"1rem",fontWeight:700,letterSpacing:".15em",textTransform:"uppercase"}}>The Curriculum</div>
          <div style={{fontSize:".65rem",color:"#555",letterSpacing:".1em",marginTop:2}}>JOHNNY · PERSONAL EDITION</div>
        </div>
        <div style={{textAlign:"right"}}>
          <div style={{fontSize:".68rem",color:"#555",letterSpacing:".08em",marginBottom:5}}>{completedCount} / {totalLessons} DONE</div>
          <div style={{width:90,height:2,background:"#1a1a1a"}}>
            <div className="pbar" style={{width:`${(completedCount/totalLessons)*100}%`}}/>
          </div>
        </div>
      </div>

      {view === "home" && (
        <div className="fi">
          <div style={{padding:"52px 36px 36px",maxWidth:660}}>
            <div style={{fontFamily:"'Playfair Display',serif",fontSize:"clamp(1.7rem,5vw,2.9rem)",fontWeight:900,lineHeight:1.15,marginBottom:16}}>
              Build the mind<br/>
              <span style={{color:"#555",fontStyle:"italic",fontWeight:400}}>no one can take from you.</span>
            </div>
            <div style={{fontFamily:"'EB Garamond',serif",fontSize:"1.05rem",color:"#666",lineHeight:1.75,maxWidth:460}}>
              Three tracks. 24 lessons written for your life — as an athlete, as a person building something worth building.
            </div>
          </div>
          <div className="hgrid">
            {tracks.map(t => {
              const done = t.topics.filter(tp => isComplete(t.id, tp)).length;
              return (
                <div key={t.id} className="tcard" onClick={() => { setActiveTrackId(t.id); setView("track"); }}>
                  <div style={{fontSize:"1.9rem",color:t.color,marginBottom:16,fontFamily:"monospace"}}>{t.icon}</div>
                  <div style={{fontFamily:"'Playfair Display',serif",fontSize:"1.2rem",fontWeight:700,marginBottom:8}}>{t.label}</div>
                  <div style={{fontFamily:"'EB Garamond',serif",fontSize:".95rem",color:"#666",lineHeight:1.6,marginBottom:22}}>{t.description}</div>
                  <div style={{fontSize:".68rem",letterSpacing:".1em",color:t.color,opacity:.8}}>{done}/{t.topics.length} LESSONS</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {view === "track" && track && (
        <div className="fi" style={{maxWidth:660,margin:"0 auto",padding:"40px 28px"}}>
          <button className="btn" onClick={() => setView("home")} style={{marginBottom:32}}>← Back</button>
          <div style={{marginBottom:40}}>
            <div style={{fontSize:"2rem",color:track.color,fontFamily:"monospace",marginBottom:12}}>{track.icon}</div>
            <div style={{fontFamily:"'Playfair Display',serif",fontSize:"1.7rem",fontWeight:700,marginBottom:8}}>{track.label}</div>
            <div style={{fontFamily:"'EB Garamond',serif",fontSize:"1rem",color:"#666"}}>{track.description}</div>
          </div>
          <div>
            {track.topics.map((topic, i) => {
              const done = isComplete(track.id, topic);
              return (
                <div key={i} className="trow" onClick={() => openLesson(track, topic)}>
                  <div style={{fontFamily:"'EB Garamond',serif",fontSize:"1.05rem",color:done?"#555":"#BEB6A6",textDecoration:done?"line-through":"none",flex:1}}>{topic}</div>
                  <div className="cc" style={{borderColor:done?track.color:"#222",background:done?track.color+"22":"transparent",color:done?track.color:"transparent"}}>✓</div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {view === "lesson" && track && (
        <div className="fi" style={{maxWidth:640,margin:"0 auto",padding:"40px 28px"}}>
          <button className="btn" onClick={() => setView("track")} style={{marginBottom:32}}>← Back to {track.label}</button>
          <div style={{fontFamily:"'Playfair Display',serif",fontSize:"1.45rem",fontWeight:700,lineHeight:1.3,marginBottom:10}}>{selectedTopic}</div>
          <div style={{fontSize:".66rem",letterSpacing:".12em",color:track.color,marginBottom:36,textTransform:"uppercase"}}>{track.label}</div>
          <div className="lbody">{lessons[`${track.id}::${selectedTopic}`]}</div>
          <div style={{marginTop:48,paddingTop:24,borderTop:"1px solid #1a1a1a"}}>
            {!isComplete(track.id, selectedTopic)
              ? <button className="btn" onClick={() => markComplete(track.id, selectedTopic)} style={{borderColor:track.color,color:track.color,padding:"12px 28px"}}>Mark as Complete ✓</button>
              : <div style={{fontFamily:"'EB Garamond',serif",fontSize:".9rem",color:track.color,fontStyle:"italic"}}>✓ Completed</div>
            }
          </div>
        </div>
      )}
    </div>
  );
}

